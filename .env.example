# ─────────────────────────────────────────────────────────────────
# Novel Writing Assistant — Environment Variables
# Copy this file to .env and fill in your values.
# NEVER commit .env to version control.
# ─────────────────────────────────────────────────────────────────

# ── PostgreSQL ────────────────────────────────────────────────────
POSTGRES_USER=notelm
POSTGRES_PASSWORD=notelm_secret
POSTGRES_DB=notelm
DATABASE_URL=postgresql+asyncpg://notelm:notelm_secret@db:5432/notelm

# For local Alembic runs (outside Docker, points to localhost):
# DATABASE_URL=postgresql+asyncpg://notelm:notelm_secret@localhost:5432/notelm

# ── Redis ────────────────────────────────────────────────────────
REDIS_URL=redis://redis:6379/0

# ── Gemini API ───────────────────────────────────────────────────
GEMINI_API_KEY=your-gemini-api-key-here

# ── Auth (Phase 9 — placeholder until real auth is wired) ────────
JWT_SECRET=change-me-to-a-long-random-string-in-production
JWT_ALGORITHM=HS256
JWT_EXPIRE_MINUTES=1440

# ── Hocuspocus (Phase 6) ─────────────────────────────────────────
HOCUSPOCUS_SECRET=change-me-hocuspocus-secret
HOCUSPOCUS_URL=ws://hocuspocus:1234

# ── Application ──────────────────────────────────────────────────
ENVIRONMENT=development
LOG_LEVEL=INFO
CORS_ORIGINS=http://localhost:5173,http://localhost:3000

# ── Cost Defaults ────────────────────────────────────────────────
DEFAULT_COST_BUDGET_CENTS=500
